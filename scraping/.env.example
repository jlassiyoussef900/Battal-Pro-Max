# Scraping Service Configuration
PORT=3002

# Indeed Configuration
INDEED_URL=https://www.indeed.com
INDEED_SEARCH_KEYWORDS=software developer
INDEED_LOCATION=United States

# Chrome Path (optional - will auto-detect if not set)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=battal_db
DB_USER=azer
DB_PASSWORD=

# Scraping Settings
SCRAPE_INTERVAL=3600000
# Interval in milliseconds (3600000 = 1 hour)

# Cron Schedule (default: every hour)
CRON_SCHEDULE=0 * * * *

# Proxy Settings (optional)
USE_PROXY=false
PROXY_URL=

# User Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
